[Desktop Entry]
Type=Application
Name=SDDM Variant Manager
GenericName=SDDM Theme Variants
Comment=Browse, preview and apply SDDM theme background variants
Exec=sddm-variant-manager
Icon=org.github.melker.sddmvariantmanager
StartupWMClass=sddm-variant-manager
Terminal=false
Categories=Qt;KDE;Settings;System;
Keywords=sddm;theme;login;variant;background;
StartupNotify=true
X-KDE-StartupClass=sddm-variant-manager
X-KDE-SubstituteUntitled=false
